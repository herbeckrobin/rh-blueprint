{
    "name": "robinherbeck/rh-blueprint",
    "description": "Wiederverwendbares Blueprint-Plugin von Robin Herbeck. Admin-Features, Peer-to-Peer Sync Network, Blueprint-Theme.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Robin Herbeck",
            "email": "dev@robinherbeck.de"
        }
    ],
    "require": {
        "php": ">=8.1",
        "yahnis-elsts/plugin-update-checker": "^5.5",
        "woocommerce/action-scheduler": "^3.9"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.12",
        "szepeviktor/phpstan-wordpress": "^1.3"
    },
    "autoload": {
        "psr-4": {
            "RhBlueprint\\": "inc/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "composer/installers": true
        }
    },
    "scripts": {
        "analyse": "phpstan analyse --memory-limit=1G",
        "lint": "phpcs"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
